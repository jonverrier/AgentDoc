{
  "name": "@jonverrier/agent-doc",
  "version": "1.0.1",
  "description": "AgentDoc — MCP server for interactive C4 architecture documentation",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonverrier/AgentDoc.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "bin": {
    "agent-doc": "dist/src/index.js",
    "c4_diagrammer": "dist/src/index.js"
  },
  "files": [
    "dist",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 src/**/*.json dist/src/",
    "prepublishOnly": "npm run build",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects unit",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects unit slow",
    "test:mini": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects mini",
    "test:slow": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects slow",
    "start": "node dist/src/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "inspector": "npx @modelcontextprotocol/inspector dist/src/index.js",
    "agent-doc": "node dist/src/index.js"
  },
  "dependencies": {
    "@jonverrier/prompt-repository": "^0.3.23",
    "@modelcontextprotocol/sdk": "0.6.1",
    "mermaid": "10.9.3",
    "selenium-webdriver": "^4.30.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.8",
    "@types/selenium-webdriver": "^4.1.28",
    "@types/sinon": "^17.0.4",
    "cheerio": "^1.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "sinon": "^19.0.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
